# Copy to env.override in this folder, then run: scripts/apply-overrides.ps1 (or .sh)
# Values here replace or append the same keys in ragflow/docker/.env (see script header).

# DeepDoc / OCR: use NVIDIA GPU (requires NVIDIA Container Toolkit)
DEVICE=gpu

# Pin image (match git tag / entrypoint in upstream for fewer surprises)
# RAGFLOW_IMAGE=infiniflow/ragflow:v0.24.0

# Optional: document engine profile (default in upstream .env is elasticsearch)
# DOC_ENGINE=elasticsearch

# Optional: mirror if pull from Docker Hub is slow
# RAGFLOW_IMAGE=registry.cn-hangzhou.aliyuncs.com/infiniflow/ragflow:latest

# Strong passwords for anything exposed beyond localhost (generate: openssl rand -hex 32)
# MYSQL_PASSWORD=
# MINIO_PASSWORD=
# ELASTIC_PASSWORD=
